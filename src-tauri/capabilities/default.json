{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "fs:default",
    "fs:allow-read",
    "fs:allow-write",
    "fs:allow-stat",
    "fs:allow-open",
    "fs:allow-fstat",
    "fs:allow-read-dir",
    "fs:allow-create",
    "fs:allow-write-file",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-copy-file",
    "fs:allow-read-file",
    "fs:write-all",
    "fs:write-files",
    "fs:read-all",
    "fs:read-dirs",
    "fs:read-files",
    "log:default",
    {
      "identifier": "fs:scope",
      "allow": [{ "path": "**/*" }]
    }
  ]
}